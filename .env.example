SECRET_KEY=change-me-to-something-random
DATABASE_URL=sqlite:///illm_dev.db
FLASK_APP=run.py
FLASK_ENV=development
MODELS_YAML_PATH=./models.yaml

# OAuth2 / OIDC provider settings
OAUTH2_CLIENT_ID=
OAUTH2_CLIENT_SECRET=
# OIDC discovery URL — Authlib fetches this to discover all endpoints + jwks_uri.
# Example (CILogon): https://cilogon.org/.well-known/openid-configuration
OAUTH2_SERVER_METADATA_URL=
OAUTH2_REDIRECT_URI=http://localhost:5000/callback
OAUTH2_SCOPES=openid email profile
