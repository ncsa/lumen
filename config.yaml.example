app:
  name: Lumen
  tagline: Illuminating AI access
  secret_key: ""
  # Dedicated secret for hashing API keys stored in the database.
  # WARNING: rotating this value invalidates ALL existing user API keys.
  # Can be overridden at runtime with the LUMEN_ENCRYPTION_KEY environment variable.
  encryption_key: ""
  database:
    url: postgresql://lumen:lumen@localhost:5678/lumen  # TimescaleDB (started by dev.sh)
    # The pool is auto-sized from the server's max_connections, split across
    # workers x replicas: 60% to pool_size, 20% to max_overflow, 20% reserved.
    # Workers are detected from WEB_CONCURRENCY or the uvicorn --workers flag;
    # replicas come from the LUMEN_REPLICAS env var (set by the Helm chart).
    # pool_size: 20        # override persistent connections (auto-sized if unset);
    # max_overflow: 60     # override burst connections (auto-sized if unset);
                           # overrides apply only if they fit within 80% of
                           # max_connections across all workers/replicas.
    # max_connections: 200 # override the detected Postgres max_connections
    pool_timeout: 10     # seconds to wait for a connection before error (default: 30)
    pool_recycle: 1800   # recycle connections after N seconds to avoid stale-connection errors
  debug: true   # set to false in production
  # announcement: ""  # WARNING: rendered as raw HTML — trusted operator input only; never accept user content here.
  # graylist_default_notice: "..."  # fallback notice shown for any graylisted model with no per-model notice set
  # theme: illinois  # Theme to use; themes live in themes/<name>/. Built-in: default, illinois, uic, uis
  # dev_user: dev@example.com  # Allows bypass of OAuth; can log in as this email directly
  # dev_user:                  # Extended form: also assigns group memberships on every login
  #   email: dev@example.com
  #   groups:
  #     - staff

oauth2:
  # Register at https://cilogon.org/oauth2/register to get client_id and client_secret
  client_id:
  client_secret:
  # Example (CILogon): https://cilogon.org/.well-known/openid-configuration
  server_metadata_url:
  redirect_uri: http://localhost:5000/callback
  scopes: openid email profile org.cilogon.userinfo  # org.cilogon.userinfo enables affiliation, member_of, idp, ou for group rules
  # Accept logins whose provider reports the email as unverified (email_verified=false).
  # Off by default; a missing email_verified claim is always accepted.
  # allow_unverified_email: false
  # Optional CILogon parameters passed to the authorization endpoint.
  # See https://www.cilogon.org/oidc for the full list.
  # Uncomment to restrict login to the University of Illinois IdP only:
  # params:
  #   idphint: urn:mace:incommon:uiuc.edu

admins:
  - admin@example.com

api:
  consent: true  # set to false to exempt API requests from the graylist model-consent requirement

  prometheus:
    enabled: false
    token: ""          # Optional. Set to a long random string to require Bearer token auth. Leave empty for no auth.
    multiproc_dir: ""  # Optional. Path for multi-worker aggregation (e.g. /tmp/prometheus_multiproc).
                       # For multiple containers, mount a shared volume at this path.

  monitoring:
    token: ""   # Set to a long random string; leave empty to disable

chat:
  upload:
    max_size_mb: 10          # maximum file size for document uploads (MB)
    max_text_chars: 100000   # maximum extracted text characters before truncation
    allowed_extensions:      # all accepted file types; backend uses magic-byte detection to classify each file
      - txt
      - md
      - csv
      - json
      - py
      - js
      - ts
      - html
      - css
      - xml
      - yaml
      - yml
      - pdf
      - png
      - jpg
      - jpeg
      - gif
      # - webp  # disabled by default; not supported by all models

rate_limiting:
  # storage_url: redis://localhost:6379/0  # omit for in-memory (single-process); requires restart to change
  limit: "30 per minute"  # applies to every endpoint, keyed by authenticated user identity

groups:
  # Groups are created/managed via the admin UI. Rules here auto-assign users at login
  # based on CILogon userinfo fields (requires org.cilogon.userinfo scope).
  # Supported matchers: contains (substring) or equals (exact match).

  # aifarms:
  #   rules:
  #     - field: member_of
  #       contains: icc-grp-aifarms   # substring match against the member_of field
  #   max: 0
  #   refresh: 0
  #   model_access:
  #     whitelist: [gpt-4o, claude-3]   # these models skip graylist for aifarms members
  #     blacklist: [deprecated-model]

  # restricted-group:
  #   model_access:
  #     default: blacklist    # deny everything not in whitelist for this group
  #     whitelist: [safe-a, safe-b]

  # staff:
  #   rules:
  #     - field: affiliation
  #       contains: staff@illinois.edu
  #     - field: idp
  #       equals: urn:mace:incommon:uiuc.edu   # exact match
  #   max: 0
  #   refresh: 0

# Project (service account) coin pool and model access.
# 'default' applies to all projects without a named entry.
# Named entries (by project name) override 'default' for that specific project.
# model_access.default: whitelist|blacklist|graylist — behavior for models not explicitly listed
# model_access.whitelist/blacklist — per-model overrides (projects cannot be assigned graylist directly;
#   they give consent through the UI when accessing a globally-graylisted model)
#projects:
#  default:
#    max: 100.0        # coin budget per project (-2 = unlimited, 0 = blocked)
#    refresh: 0.0      # coins added per hour
#    starting: 100.0   # coins when pool is first created
#    model_access:
#      default: whitelist   # allow all models not explicitly listed
#      blacklist: []        # always deny these models for all projects
#      whitelist: []        # always allow these models for all projects
#
#  research-bot:       # overrides default for this specific project
#    max: 500.0
#    refresh: 1.0
#    starting: 500.0
#    model_access:
#      default: blacklist   # deny everything not in whitelist
#      whitelist: [gpt-4o, llama3]

models:
  # The top-level "name" is Lumen's internal model identifier — what callers use in API requests.
  # Each endpoint can optionally set "model" to override what name is sent to that endpoint,
  # allowing endpoints with different model identifiers to back the same Lumen model.

  - name: gpt-4o
    active: true
    input_cost_per_million: 5.0     # coins per 1M input tokens
    output_cost_per_million: 15.0   # coins per 1M output tokens
    # max_input_tokens: 128000        # optional; context window size
    # supports_function_calling: true # optional; tool/function call support
    # supports_vision: true           # optional; image input support (used by upload UI)
    endpoints:
      - url: https://api.openai.com/v1
        api_key: sk-abc123
        # model: gpt-4o             # optional; defaults to the parent "name" if omitted
      - url: https://api.openai.com/v1
        api_key: sk-def456          # second key; round-robin between these two

  - name: gpt-4o-mini
    active: true
    input_cost_per_million: 0.15
    output_cost_per_million: 0.6
    endpoints:
      - url: https://api.openai.com/v1
        api_key: sk-abc123

  - name: claude-3-opus
    active: true
    input_cost_per_million: 15.0
    output_cost_per_million: 75.0
    endpoints:
      - url: https://api.anthropic.com/v1
        api_key: sk-ant-xyz
        model: claude-3-opus-20240229   # actual model id at the Anthropic endpoint

  # Ollama — local models via OpenAI-compatible API (http://localhost:11434/v1)
  # Ollama doesn't enforce API keys; use any non-empty string.
  - name: llama3
    active: true
    input_cost_per_million: 0.0
    output_cost_per_million: 0.0
    endpoints:
      - url: http://localhost:11434/v1
        api_key: ollama
        model: llama3.2             # actual tag pulled in Ollama

  - name: mistral
    active: true
    input_cost_per_million: 0.0
    output_cost_per_million: 0.0
    endpoints:
      - url: http://localhost:11434/v1
        api_key: ollama
        model: mistral

  # Example: same Lumen model name backed by both a cloud endpoint and a local Ollama fallback.
  # Round-robin will distribute load; the health checker will skip unhealthy ones.
  - name: phi3
    active: true
    input_cost_per_million: 0.0
    output_cost_per_million: 0.0
    endpoints:
      - url: http://localhost:11434/v1
        api_key: ollama
        model: phi3
      - url: http://gpu-server.internal/v1
        api_key: internal-key
        model: phi-3-mini-128k-instruct   # different name at the internal endpoint
